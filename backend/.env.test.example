# Test environment — copy to .env.test and fill in values.
# IMPORTANT: use a SEPARATE database (waste_collection_test) from your dev DB.
# Tests truncate tables between runs; if you point this at your dev DB
# you will lose all your seed data.
#
# Setup (one time):
#   createdb waste_collection_test
#   node --env-file=.env.test src/config/migrate.js
#
# Then run tests any time with:
#   npm test

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=waste_collection_test

CORS_ORIGIN=http://localhost:3000
JWT_SECRET=test_secret_for_vitest_not_for_production
JWT_EXPIRES_IN=1h
PORT=5001
