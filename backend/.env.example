PORT=5000
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=waste_collection
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ── Two-factor authentication ──────────────────────────────────────────
# Email one-time-code 2FA at login. Leave on (default) for security; set to
# false to fall back to single-step login.
MFA_ENABLED=true

# ── Email (Nodemailer / SMTP) ──────────────────────────────────────────
# Optional. If SMTP_HOST is left blank, all emails (login codes, complaint and
# schedule notifications) are printed to the server console instead of sent —
# handy for local dev. Fill these in to actually deliver mail.
#   Dev testing:  https://mailtrap.io  (free inbox, gives you host/port/user/pass)
#   Production:   any SMTP host, e.g. Gmail with an app password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WasteCoord Nairobi <no-reply@wastecoord.ke>
APP_NAME=WasteCoord Nairobi
